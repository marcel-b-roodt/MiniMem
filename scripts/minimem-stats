#!/bin/bash
# scripts/minimem-stats — Quick summary of MiniMem compression stats
#
# Usage:
#   minimem-stats              # Global stats
#   minimem-stats --per-process  # Detailed per-process (root)
#   minimem-stats --summary      # Anonymized UID summary
#   minimem-stats --watch        # Continuous update (2s interval)

SYSDIR="/sys/kernel/minimem"
DEBUGDIR="/sys/kernel/debug/minimem"

fmt_bytes() {
    local bytes=$1
    if [ "$bytes" -ge 1073741824 ] 2>/dev/null; then
        echo "$(echo "scale=1; $bytes / 1073741824" | bc)G"
    elif [ "$bytes" -ge 1048576 ] 2>/dev/null; then
        echo "$(echo "scale=1; $bytes / 1048576" | bc)M"
    elif [ "$bytes" -ge 1024 ] 2>/dev/null; then
        echo "$(echo "scale=1; $bytes / 1024" | bc)K"
    else
        echo "${bytes}B"
    fi
}

show_global() {
    if [ ! -d "$SYSDIR" ]; then
        echo "MiniMem module not loaded"
        echo "Load with: sudo modprobe minimem"
        exit 1
    fi

    echo "=== MiniMem Global Stats ==="
    echo ""

    local pages_cmp=$(cat "$SYSDIR/pages_compressed" 2>/dev/null || echo 0)
    local pages_decmp=$(cat "$SYSDIR/pages_decompressed" 2>/dev/null || echo 0)
    local bytes_saved=$(cat "$SYSDIR/bytes_saved" 2>/dev/null || echo 0)
    local cmp_count=$(cat "$SYSDIR/compress_count" 2>/dev/null || echo 0)
    local decmp_count=$(cat "$SYSDIR/decompress_count" 2>/dev/null || echo 0)
    local cmp_avg=$(cat "$SYSDIR/compress_avg_ns" 2>/dev/null || echo 0)
    local decmp_avg=$(cat "$SYSDIR/decompress_avg_ns" 2>/dev/null || echo 0)
    local zswap_pages=$(cat "$SYSDIR/zswap_pages" 2>/dev/null || echo 0)
    local zswap_saved=$(cat "$SYSDIR/zswap_saved" 2>/dev/null || echo 0)
    local pool_pages=$(cat "$SYSDIR/pool_pages" 2>/dev/null || echo 0)
    local scanner=$(cat "$SYSDIR/scanner_enabled" 2>/dev/null || echo 0)
    local patches=$(cat "$SYSDIR/kernel_patches" 2>/dev/null || echo 0)
    local par_mode=$(cat "$SYSDIR/parallel_mode" 2>/dev/null || echo "?")
    local hook_faults=$(cat "$SYSDIR/hook_faults" 2>/dev/null || echo 0)

    echo "  Compression:"
    echo "    Pages compressed:     $pages_cmp"
    echo "    Pages decompressed:  $pages_decmp"
    echo "    Bytes saved:          $(fmt_bytes $bytes_saved)"
    echo "    Avg compress time:    ${cmp_avg} ns"
    echo "    Avg decompress time: ${decmp_avg} ns"
    echo ""
    echo "  Pool:"
    echo "    Compressed pages:     $zswap_pages"
    echo "    Bytes saved (pool):   $(fmt_bytes $zswap_saved)"
    echo "    Pool memory pages:    $pool_pages"
    echo ""
    echo "  Scanner:"
    echo "    Enabled:             $scanner"
    echo "    Kernel patches:      $patches"
    echo "    Hook faults:         $hook_faults"
    echo "    Parallel mode:       $par_mode"
    echo ""
    echo "  Per-process stats:"
    local pp=$(cat "$SYSDIR/per_process_stats" 2>/dev/null || echo "?")
    echo "    Enabled:             $pp"
}

show_summary() {
    if [ ! -f "$SYSDIR/stats_summary" ]; then
        echo "stats_summary not available (module not loaded?)"
        exit 1
    fi

    echo "=== MiniMem Stats Summary (anonymized) ==="
    echo ""
    cat "$SYSDIR/stats_summary"
}

show_per_process() {
    if [ ! -f "$DEBUGDIR/per_process" ]; then
        echo "per_process not available"
        echo "Module not loaded, or debugfs not mounted, or not root"
        exit 1
    fi

    local pp=$(cat "$SYSDIR/per_process_stats" 2>/dev/null || echo "?")
    if [ "$pp" = "0" ]; then
        echo "Per-process stats are disabled. Enable with:"
        echo "  echo 1 | sudo tee $SYSDIR/per_process_stats"
        exit 0
    fi

    echo "=== MiniMem Per-Process Stats ==="
    echo ""
    cat "$DEBUGDIR/per_process"
}

case "${1:-global}" in
    --per-process|-p)
        show_per_process
        ;;
    --summary|-s)
        show_summary
        ;;
    --watch|-w)
        while true; do
            clear
            show_global
            echo ""
            show_summary 2>/dev/null || true
            sleep 2
        done
        ;;
    --global|-g|global|"")
        show_global
        ;;
    --help|-h)
        echo "Usage: $0 [--per-process|--summary|--watch|--global|--help]"
        echo ""
        echo "  --global       Show global compression stats (default)"
        echo "  --summary      Show anonymized UID-level summary"
        echo "  --per-process  Show detailed per-process stats (root)"
        echo "  --watch        Continuous 2s update of global + summary"
        echo "  --help         This help"
        ;;
    *)
        echo "Unknown option: $1"
        echo "Use --help for usage information"
        exit 1
        ;;
esac