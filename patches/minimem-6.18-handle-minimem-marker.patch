From: MiniMem Project <minimem@noreply.github.com>
Subject: [PATCH] mm/memory: handle PTE_MARKER_MINIMEM in handle_pte_marker()

This patch adds support for MiniMem compressed page markers in the
kernel's page fault handler. When a process accesses a page that has
been compressed by MiniMem and replaced with a PTE marker, the fault
handler intercepts the marker, decompresses the page, and installs
a present PTE — transparently to the application.

Without this patch, MiniMem PTE markers fall through to the "unknown
marker" case in handle_pte_marker() and return VM_FAULT_SIGBUS.

The patch uses a function pointer (minimem_fault_handler) that is
registered by the MiniMem module at load time. This allows MiniMem
to remain a loadable kernel module while integrating cleanly with
the page fault handler.

Signed-off-by: MiniMem Project <minimem@noreply.github.com>
---
 include/linux/minimem.h | 34 ++++++++++++++++++++++++++++++++++
 include/linux/swapops.h |  3 ++-
 mm/memory.c             | 14 ++++++++++++++
 3 files changed, 50 insertions(+), 1 deletion(-)

diff --git a/include/linux/minimem.h b/include/linux/minimem.h
new file mode 100644
index 000000000000..791a8fa70d4d
--- /dev/null
+++ b/include/linux/minimem.h
@@ -0,0 +1,34 @@
+/* SPDX-License-Identifier: GPL-2.0-only */
+/*
+ * minimem.h — Kernel interface for MiniMem transparent memory compression
+ *
+ * Declares the PTE marker bit and fault handler registration API used by
+ * the MiniMem kernel module and the page fault handler.
+ */
+
+#ifndef _LINUX_MINIMEM_H
+#define _LINUX_MINIMEM_H
+
+#include <linux/mm.h>
+#include <linux/mm_types.h>
+
+/* PTE marker bit for MiniMem compressed pages (bits 0-2 are uffd/wp/poison/guard) */
+#define PTE_MARKER_MINIMEM	BIT(3)
+
+#ifdef CONFIG_MINIMEM
+/*
+ * Fault handler registered by the MiniMem module.
+ * Called from handle_pte_marker() when a PTE_MARKER_MINIMEM fault is detected.
+ * Returns VM_FAULT_NOPAGE on success (page installed in PTE),
+ * or a VM_FAULT_* error code on failure.
+ */
+extern vm_fault_t (*minimem_fault_handler)(struct vm_fault *vmf);
+
+int minimem_register_fault_handler(vm_fault_t (*handler)(struct vm_fault *vmf));
+void minimem_unregister_fault_handler(void);
+#else
+#define minimem_fault_handler NULL
+static inline int minimem_register_fault_handler(vm_fault_t (*handler)(struct vm_fault *vmf)) { return 0; }
+static inline void minimem_unregister_fault_handler(void) {}
+#endif
+
+#endif /* _LINUX_MINIMEM_H */
diff --git a/include/linux/swapops.h b/include/linux/swapops.h
index 64ea151a7d23..6f992d69b7f0 100644
--- a/include/linux/swapops.h
+++ b/include/linux/swapops.h
@@ -421,7 +421,8 @@ typedef unsigned long pte_marker;
  * PROT_NONE, rather than if they were a memory hole or equivalent.
  */
 #define  PTE_MARKER_GUARD			BIT(2)
-#define  PTE_MARKER_MASK			(BIT(3) - 1)
+#define  PTE_MARKER_MINIMEM			BIT(3)
+#define  PTE_MARKER_MASK			(BIT(4) - 1)
 
 static inline swp_entry_t make_pte_marker_entry(pte_marker marker)
 {
diff --git a/mm/memory.c b/mm/memory.c
index b59ae7ce42d4..4d173a0305f1 100644
--- a/mm/memory.c
+++ b/mm/memory.c
@@ -61,6 +61,7 @@
 #include <linux/memcontrol.h>
 #include <linux/mmu_notifier.h>
 #include <linux/swapops.h>
+#include <linux/minimem.h>
 #include <linux/elf.h>
 #include <linux/gfp.h>
 #include <linux/migrate.h>
@@ -4384,6 +4385,7 @@ static vm_fault_t handle_pte_marker(struct vm_fault *vmf)
 {
 	swp_entry_t entry = pte_to_swp_entry(vmf->orig_pte);
 	unsigned long marker = pte_marker_get(entry);
+	vm_fault_t ret;
 
 	/*
 	 * PTE markers should never be empty.  If anything weird happened,
@@ -4403,6 +4405,18 @@ static vm_fault_t handle_pte_marker(struct vm_fault *vmf)
 	if (pte_marker_entry_uffd_wp(entry))
 		return pte_marker_handle_uffd_wp(vmf);
 
+#ifdef CONFIG_MINIMEM
+	/* Handle MiniMem compressed page markers */
+	if (marker & PTE_MARKER_MINIMEM) {
+		if (minimem_fault_handler) {
+			ret = minimem_fault_handler(vmf);
+			return ret;
+		}
+		pr_warn_once("minimem: fault on MINIMEM marker but handler not registered\n");
+		return VM_FAULT_SIGBUS;
+	}
+#endif
+
 	/* This is an unknown pte marker */
 	return VM_FAULT_SIGBUS;
 }